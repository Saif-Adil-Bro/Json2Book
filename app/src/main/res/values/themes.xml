<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme (Material3 dynamic / light) -->
    <style name="Theme.DynamicBookReader" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash Screen theme — used only for the launch window -->
    <style name="Theme.DynamicBookReader.SplashScreen" parent="Theme.DynamicBookReader">
        <!-- postSplashScreenTheme restores the real theme after the splash -->
        <item name="android:windowSplashScreenBackground">#1A3A5C</item>
        <item name="postSplashScreenTheme">@style/Theme.DynamicBookReader</item>
    </style>

</resources>
