<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DynamicBookReader" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.DynamicBookReader.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1A3A5C</item>
        <item name="postSplashScreenTheme">@style/Theme.DynamicBookReader</item>
    </style>

</resources>
